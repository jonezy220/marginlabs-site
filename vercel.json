{
  "cleanUrls": true,
  "trailingSlash": false,
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.marginlabs.io" }],
      "destination": "https://marginlabs.io/:path*",
      "permanent": true
    },
    {
      "source": "/execution-playbook",
      "destination": "/advisory",
      "permanent": false
    }
  ],
  "functions": {
    "api/stripe-webhook.js": {
      "maxDuration": 30
    }
  }
}
